```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Database files
*.db
*.sqlite
*.sqlite3

# Dependencies
.venv/
venv/
env/

# Logs and temporary files
*.log
*.tmp
*.temp
*.cache

# Environment variables
.env
.env.local
*.env.*

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
```