# Скопируйте в .env и заполните (файл .env в git не попадает)

# Токен VK API — https://vkhost.github.io/
VK_TOKEN=

# Ссылка или ID группы (https://vk.ru/your_group или apng_archiver)
VK_GROUP_LINK=

# Сколько постов подтягивать при загрузке (по умолчанию 20)
POST_COUNT=20

# Тема: light | dark | system
APP_THEME=dark

# --- Cookies для yt-dlp (видео/клипы с ограниченным доступом) ---
# Путь к cookies.txt в формате Netscape (экспорт из браузера или расширения)
# VK_COOKIES_FILE=cookies.txt

# Читать cookies из браузера (на Windows часто ошибка DPAPI — лучше cookies.txt)
# VK_USE_BROWSER_COOKIES=0

# Браузеры для автоматического чтения cookies (только если VK_USE_BROWSER_COOKIES=1)
# VK_COOKIES_BROWSER=edge,chrome,firefox
